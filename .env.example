APP_NAME=EntryEase
APP_ENV=local
APP_KEY=
APP_DEBUG=true

# Must match the ENTRYEASE_URL value on DEORIS so SSO and federated search resolve correctly.
APP_URL=https://entryease.deoris.test

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=entry_ease_db
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=.deoris.test
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=none

# Safe default — portal bell is primary. Enable reverb only for standalone Echo.
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# database works on XAMPP without Redis; use redis when available
QUEUE_CONNECTION=database

CACHE_STORE=database

# Use predis on XAMPP/Windows unless you install phpredis (PECL). phpredis without ext-redis causes "Class Redis not found".
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_PUBSUB_DB=2

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@entryease.test"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# ── DEORIS Portal (required for main notification bell) ───────
APP_PORTAL_URL=https://deoris.test
AUTH_SERVICE_URL=https://deoris.test
DEORIS_PORTAL_URL=https://deoris.test
DEORIS_PORTAL_PUBLISH_ENABLED=true
# Leave false (default): HTTP ingest only. Redis publish + portal deoris:events:listen duplicates every notification.
DEORIS_PORTAL_PUBLISH_REDIS=false
DEORIS_PORTAL_QUEUE=deoris-events
DEORIS_PORTAL_REDIS_CHANNEL=deoris.events

# Must match DEORIS sibling install: C:\xampp\htdocs\DEORIS\.env (ENTRYEASE_EVENT_SECRET)
ENTRYEASE_EVENT_SECRET=change-me-entryease

# Same random string as DEORIS ENTRYEASE_SEARCH_TOKEN — required for portal search bar to query students here
ENTRYEASE_SEARCH_TOKEN=change-me-search-token

# ── EntryEase module identity ───────────────────────────────────
DEORIS_MODULE_NAME=EntryEase
DEORIS_EVENT_VERSION=1.0
DEORIS_MODULE_BUS_ENABLED=false
DEORIS_REDIS_PUBSUB_CONNECTION=pubsub

# ── Optional standalone realtime (not needed when embedded) ─────
DEORIS_BROADCAST_ENABLED=false
REVERB_APP_ID=entryease
REVERB_APP_KEY=entryease-key
REVERB_APP_SECRET=entryease-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http
REVERB_ALLOWED_ORIGINS=https://entryease.deoris.test,https://deoris.test,http://localhost

REDIS_QUEUE=default
REDIS_QUEUE_CONNECTION=default

# ---------------------------------------------------------------------------
# Production public config template (copy values into .env on the VPS)
